# ============================================================
# Quiet Eyes Backend Configuration
# ============================================================
# Copy this file to .env and fill in the values.

# --- Anthropic / Claude (required for AI features) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
# Service role key — only needed for seed_data.py script
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Server ---
HOST=0.0.0.0
PORT=8015
DEBUG=true

# --- CORS ---
# Comma-separated list of allowed origins.
# In production, set to your actual domain(s).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- Super Admin ---
# Supabase Auth UID of the super-admin user (for /admin endpoints).
SUPER_ADMIN_UID=

# --- Twilio / WhatsApp (optional) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Tavily Search API (optional — used by lead sniper) ---
# TAVILY_API_KEY=
