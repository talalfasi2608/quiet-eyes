# ═══════════════════════════════════════════════════════════
# Quieteyes — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# ── Database (Supabase) — REQUIRED ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (Anthropic Claude) — REQUIRED ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Places + Geocoding ──
# Enable: Places API + Geocoding API at console.cloud.google.com
# Free $200/month credit
GOOGLE_PLACES_API_KEY=AIza...

# ── Apify (Facebook lead scraping) ──
# Sign up at apify.com, free $5/month credit
APIFY_API_TOKEN=apify_api_...

# ── SerpAPI (Google Trends + Search) ──
# Sign up at serpapi.com, free 100 searches/month
SERPAPI_KEY=...

# ── Tavily (news + trends search) ──
# Sign up at tavily.com, free 1000 searches/month
TAVILY_API_KEY=tvly-...

# ── WhatsApp — Green API (primary) ──
# Sign up at green-api.com, connect your WhatsApp number
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ── WhatsApp — Twilio (fallback) ──
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Stripe (payments) ──
STRIPE_SECRET_KEY=sk_...

# ── Server ──
HOST=0.0.0.0
PORT=8015
DEBUG=true
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Admin ──
SUPER_ADMIN_UID=
ADMIN_PHONE=972XXXXXXXXX
ADMIN_EMAIL=admin@quieteyes.co.il
