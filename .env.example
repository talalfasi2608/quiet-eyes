# ============================================================
# Quiet Eyes Frontend Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Vite requires the VITE_ prefix for env vars to be exposed to the browser.

# --- Backend API URL ---
# In development: http://localhost:8015
# In production: https://api.quieteyes.io (or your domain)
VITE_API_URL=http://localhost:8015

# --- Supabase (client-side auth) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
